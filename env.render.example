# ====================================
# HMS - Render Production Environment Variables
# ====================================
# Copy this file to configure your Render deployment
# Set these values in the Render Dashboard → Environment Variables
# ====================================

# =================
# Django Core Settings
# =================
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
PYTHON_VERSION=3.11.5

# Allowed Hosts - Add your Render domain(s)
# Example: hms-web.onrender.com,yourdomain.com
ALLOWED_HOSTS=hms-web.onrender.com

# Site URL - Your production domain
# Example: https://hms-web.onrender.com
SITE_URL=https://hms-web.onrender.com

# =================
# Database Configuration
# =================
# Render will automatically set DATABASE_URL from the PostgreSQL service
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://hms_user:password@hostname:5432/hms_production

# Database connection pooling
DATABASE_CONN_MAX_AGE=600
DATABASE_CONN_HEALTH_CHECKS=True
DATABASE_TIMEOUT=10
DATABASE_SSL_MODE=prefer

# =================
# Redis Configuration
# =================
# Render will automatically set REDIS_URL from the Redis service
REDIS_URL=redis://hostname:6379/0
USE_REDIS_CACHE=True

# =================
# CORS Settings
# =================
# Add your frontend domain(s) separated by commas
# Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# =================
# Email Configuration
# =================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# =================
# SMS Configuration (SMS Notify GH)
# =================
SMS_API_KEY=your-sms-api-key-here
SMS_SENDER_ID=PrimeCare
SMS_API_URL=https://sms.smsnotifygh.com/smsapi

# =================
# WhatsApp Configuration (Optional)
# =================
# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta WhatsApp Business API (Alternative)
USE_META_WHATSAPP_API=False
META_WHATSAPP_ACCESS_TOKEN=your-meta-access-token
META_WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# =================
# Hospital Branding
# =================
HOSPITAL_NAME=PrimeCare Hospital
HOSPITAL_LOGO_URL=https://yourdomain.com/logo.png

# =================
# Security Settings
# =================
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# =================
# Error Tracking (Optional)
# =================
# Sentry DSN for error monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =================
# Storage Configuration (Optional)
# =================
# For file uploads - use Render Disk or cloud storage
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# =================
# Render-Specific Settings
# =================
# These are automatically set by Render
# PORT=10000  # Set by Render
# RENDER=true  # Set by Render
# RENDER_SERVICE_NAME=hms-web  # Set by Render

