# Django Core Settings
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# CSRF Configuration (for local network access)
# Add your local network IP addresses here (e.g., 192.168.1.100)
# CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://192.168.1.100:8000

# Database Configuration (Choose ONE based on your setup)

# ==============================================================================
# LOCAL DATABASE (Same server as application)
# ==============================================================================

# MySQL - Local (Managed Servers like cPanel, Plesk, etc.)
DATABASE_URL=mysql://username:password@localhost:3306/database_name

# PostgreSQL - Local
# DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# SQLite - Development only (NOT for production)
# DATABASE_URL=sqlite:///db.sqlite3

# ==============================================================================
# REMOTE DATABASE (Separate dedicated database server) - RECOMMENDED
# ==============================================================================

# PostgreSQL - Remote Server (Best for production)
# DATABASE_URL=postgresql://hms_user:SecurePassword123@192.168.1.20:5432/hms_production
# DATABASE_SSL_MODE=require
# DATABASE_CONN_MAX_AGE=600
# DATABASE_CONN_HEALTH_CHECKS=True
# DATABASE_TIMEOUT=10

# MySQL - Remote Server
# DATABASE_URL=mysql://hms_user:SecurePassword123@192.168.1.20:3306/hms_production

# ==============================================================================
# CLOUD MANAGED DATABASES (Fully managed, highly available)
# ==============================================================================

# AWS RDS PostgreSQL
# DATABASE_URL=postgresql://hms_user:password@hms-db.c9akl7xvbqmf.us-east-1.rds.amazonaws.com:5432/hms_production?sslmode=require

# AWS RDS MySQL
# DATABASE_URL=mysql://admin:password@hms-db.c9akl7xvbqmf.us-east-1.rds.amazonaws.com:3306/hms_production

# Google Cloud SQL PostgreSQL
# DATABASE_URL=postgresql://hms_user:password@34.123.45.67:5432/hms_production

# Google Cloud SQL MySQL
# DATABASE_URL=mysql://root:password@35.123.45.67:3306/hms_production

# Azure Database for PostgreSQL
# DATABASE_URL=postgresql://hms_user@hms-server:password@hms-server.postgres.database.azure.com:5432/hms_production?sslmode=require

# DigitalOcean Managed Database PostgreSQL
# DATABASE_URL=postgresql://doadmin:password@hms-db-do-user-123456-0.b.db.ondigitalocean.com:25060/hms_production?sslmode=require

# Heroku PostgreSQL
# DATABASE_URL=postgresql://user:pass@ec2-52-21-252-142.compute-1.amazonaws.com:5432/d8fjk3lk4j5l

# ==============================================================================
# DATABASE PERFORMANCE SETTINGS (Optional - Defaults work well)
# ==============================================================================

# Connection pooling (keep connections alive for N seconds)
# DATABASE_CONN_MAX_AGE=600

# Health check connections before use
# DATABASE_CONN_HEALTH_CHECKS=True

# Connection timeout (seconds)
# DATABASE_TIMEOUT=10

# ==============================================================================
# SSL/TLS CONFIGURATION (For secure remote connections)
# ==============================================================================

# SSL Mode Options:
# - disable: No SSL (only for local/trusted networks)
# - allow: Try SSL, fall back to non-SSL
# - prefer: Try SSL first (default)
# - require: Force SSL, don't verify certificate
# - verify-ca: Force SSL, verify certificate authority
# - verify-full: Force SSL, verify CA and hostname (most secure)
DATABASE_SSL_MODE=prefer

# SSL Certificate Files (only needed for verify-ca or verify-full modes)
# DATABASE_SSL_ROOT_CERT=/path/to/ca-cert.pem
# DATABASE_SSL_CERT=/path/to/client-cert.pem
# DATABASE_SSL_KEY=/path/to/client-key.pem

# Redis Configuration (for caching and Celery)
REDIS_URL=redis://127.0.0.1:6379/0
USE_REDIS_CACHE=True

# Security Settings
SECURE_SSL_REDIRECT=True

# CORS Settings
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# SMS Configuration (SMS Notify GH)
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=YourHospital
SMS_API_URL=https://sms.smsnotifygh.com/smsapi

# Site Configuration
SITE_URL=https://yourdomain.com
HOSPITAL_NAME=Your Hospital Name
HOSPITAL_LOGO_URL=https://yourdomain.com/static/logo.png

# WhatsApp Configuration (Optional - Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# WhatsApp Configuration (Optional - Meta Business API)
USE_META_WHATSAPP_API=False
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=

# Error Monitoring (Optional - Sentry)
SENTRY_DSN=

# Admin Notification Emails (comma-separated: Name:email,Name2:email2)
ADMINS=Admin Name:admin@yourdomain.com

# Static Files (for cloud storage - optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
