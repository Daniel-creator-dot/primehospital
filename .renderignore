# Renderignore - Files and directories to exclude from Render deployment
# Similar to .gitignore but specifically for Render builds

# Local development
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
.pytest_cache/

# Environment files
.env
.env.local
*.env
!env.render.example
!env.example

# Local databases
*.sqlite3
*.db
db.sqlite3
db.sqlite3-shm
db.sqlite3-wal

# Celery
celerybeat-schedule*
celerybeat.pid

# Media files (optional - depends on your storage strategy)
# media/

# Logs
*.log
logs/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Documentation (optional - include if you want docs on production)
*.md
!README.md
!RENDER_DEPLOYMENT_GUIDE.md

# Test files
tests/
test_*.py
*_test.py

# Backup files
backups/
*.bak
*.backup
*.dump

# Git
.git/
.gitignore
.gitattributes

# Docker (if not using Render's Docker deployment)
# Dockerfile
# docker-compose.yml

# CI/CD (if not using)
.github/
.gitlab-ci.yml

# Large binary files
*.mp4
*.mov
*.avi
*.zip
*.tar.gz

# Temporary files
tmp/
temp/
*.tmp

